# Azure DevOps
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_TEAM=

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Email delivery (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=team-lead@yourcompany.com,manager@yourcompany.com

# App config
RUN_HOUR=18
RUN_MINUTE=0
COMMENT_LOOKBACK_DAYS=3
COPY_PASTE_THRESHOLD=0.92
RISK_FLAG_THRESHOLD=60
