# ============================================================================
# Secrets & Key Vault (optional)
# ============================================================================
# If set, secrets below (anything pulled via utils.secrets.get_secret) are
# resolved from this Azure Key Vault first, falling back to the plain env
# vars below if not found. Leave unset for local dev / small deployments —
# behavior is then identical to a flat .env file. See README "Secrets &
# Key Vault" for setup.
KEY_VAULT_URL=

# ============================================================================
# Authentication
# ============================================================================
# "pat" (default, backward compatible) or "service_principal" (recommended
# for production — doesn't break when an individual's PAT expires/they leave)
AZURE_AUTH_MODE=pat

# Azure DevOps
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_TEAM=your-team-name

# Used when AZURE_AUTH_MODE=pat
AZURE_DEVOPS_PAT=your-personal-access-token

# Used when AZURE_AUTH_MODE=service_principal (see README "Authentication")
AZURE_DEVOPS_SP_TENANT_ID=
AZURE_DEVOPS_SP_CLIENT_ID=
AZURE_DEVOPS_SP_CLIENT_SECRET=

# ============================================================================
# Multi-team support (optional)
# ============================================================================
# JSON list of teams to process in one run. If unset, the single team
# defined by AZURE_DEVOPS_* above is used. See README "Multi-team Support".
# TEAMS_CONFIG=[{"name":"platform","azure_project":"Platform","azure_team":"Platform Team"},{"name":"growth","azure_project":"Growth","azure_team":"Growth Team"}]
TEAMS_CONFIG=

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# ============================================================================
# Email delivery
# ============================================================================
# "smtp" (default, Gmail App Password), "sendgrid", or "acs" (Azure
# Communication Services). sendgrid/acs give delivery receipts and bounce
# handling — see README "Email Delivery".
EMAIL_PROVIDER=smtp

# Used when EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Used when EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=

# Used when EMAIL_PROVIDER=acs
AZURE_COMMUNICATION_CONNECTION_STRING=

EMAIL_FROM=your-email@gmail.com
EMAIL_TO=team-lead@yourcompany.com,manager@yourcompany.com
EMAIL_NOTIFY_STATES=Active
# State where email is only sent if comment quality is below threshold
EMAIL_QUALITY_GATE_STATE=Resolved
# Quality score (0-10) at or above which individual emails stop being sent
EMAIL_GOOD_QUALITY_THRESHOLD=7

# ============================================================================
# Teams integration (optional)
# ============================================================================
# Incoming Webhook URL for the target Teams channel. If unset, Teams
# delivery is skipped (email-only). See README "Teams Integration".
TEAMS_WEBHOOK_URL=

# ============================================================================
# Databricks SQL Warehouse
# ============================================================================
# Server hostname: adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
# HTTP path: /sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
# Personal access token from Databricks workspace settings
DATABRICKS_ACCESS_TOKEN=your-databricks-pat
# Catalog and schema (database) where tables will be created
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=eod_task_monitor

# ============================================================================
# Scheduling (see README "Scheduling & Deployment")
# ============================================================================
# RUN_HOUR/RUN_MINUTE only matter in --schedule (local/fallback) mode.
# Production should trigger `python main.py` externally (Azure Functions
# timer trigger / Databricks Workflow / cron) once per business day.
RUN_HOUR=18
RUN_MINUTE=0
SKIP_WEEKENDS=true
# Explicit extra holiday dates (comma-separated ISO dates)
HOLIDAYS=
# Optional: also skip public holidays for this country (e.g. US, GB, IN)
HOLIDAY_COUNTRY=

# ============================================================================
# Business rules
# ============================================================================
COMMENT_LOOKBACK_DAYS=3
COPY_PASTE_THRESHOLD=0.92
RISK_FLAG_THRESHOLD=60
PERSIST_COMMENT_HISTORY=true
COMMENT_HISTORY_MAX_PER_ASSIGNEE=60

# ============================================================================
# Concurrency / scalability (see README "Scalability")
# ============================================================================
MAX_CONCURRENT_TASK_WORKERS=8
TASK_COUNT_WARNING_THRESHOLD=50

# ============================================================================
# Observability (see README "Observability")
# ============================================================================
RUN_DEADLINE_MINUTES=30
METRICS_ALERT_ON_FAILURE=true
