# Azure DevOps
AZURE_DEVOPS_ORG=your-organization-name
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_PAT=your-personal-access-token
AZURE_DEVOPS_TEAM=your-team-name

# Groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Email delivery (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_TO=team-lead@yourcompany.com,manager@yourcompany.com
EMAIL_NOTIFY_STATES=Active
# State where email is only sent if comment quality is below threshold
EMAIL_QUALITY_GATE_STATE=Resolved
# Quality score (0-10) at or above which individual emails stop being sent
EMAIL_GOOD_QUALITY_THRESHOLD=7

# Databricks SQL Warehouse
# Server hostname: adb-XXXXXXXXXXXXXXXX.X.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=your-workspace.azuredatabricks.net
# HTTP path: /sql/1.0/warehouses/XXXXXXXXXXXXXXXX
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
# Personal access token from Databricks workspace settings
DATABRICKS_ACCESS_TOKEN=your-databricks-pat
# Catalog and schema (database) where tables will be created
DATABRICKS_CATALOG=hive_metastore
DATABRICKS_SCHEMA=eod_task_monitor


# App config
RUN_HOUR=18
RUN_MINUTE=0
COMMENT_LOOKBACK_DAYS=3
COPY_PASTE_THRESHOLD=0.92
RISK_FLAG_THRESHOLD=60